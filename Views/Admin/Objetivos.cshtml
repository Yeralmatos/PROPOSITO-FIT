@model List<PropositoFit.Models.Objetivo>

@{
    Layout = null;
    var buscar = ViewBag.Buscar as string;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Objetivos - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-4">
        <div class="d-flex justify-content-between mb-3">
            <div>
                <h2 class="fw-bold">Gestión de Objetivos</h2>
                <p class="text-muted">Objetivos disponibles para los usuarios.</p>
            </div>
            <a href="/Admin/NuevoObjetivo" class="btn btn-success">+ Nuevo Objetivo</a>
        </div>

        <form method="get" asp-action="Objetivos" class="mb-3">
            <div class="input-group">
                <input name="buscar" value="@buscar" class="form-control" placeholder="Buscar objetivo..." />
                <button class="btn btn-primary">Buscar</button>
            </div>
        </form>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info text-center">No hay objetivos registrados.</div>
                }
                else
                {
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                                <th>Fecha</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.Nombre</td>
                                    <td>@item.Descripcion</td>
                                    <td>@item.Prioridad</td>
                                    <td>
                                        <span class="badge bg-success">@item.Estado</span>
                                    </td>
                                    <td>@item.FechaCreacion.ToShortDateString()</td>
                                    <td>
                                        <a href="/Admin/EditarObjetivo/@item.Id" class="btn btn-sm btn-primary">Editar</a>

                                        <form asp-action="EliminarObjetivo" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button class="btn btn-sm btn-danger"
                                                    onclick="return confirm('¿Eliminar objetivo? También se eliminarán sus rutinas relacionadas.')">
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

</body>
</html>