@{
    Layout = null;
    ViewData["Title"] = "Dashboard";
    var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Panel Administrativo - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f6fa;
            font-family: Arial, sans-serif;
        }

        .header-admin {
            background: linear-gradient(135deg, #111827, #1f2937);
            padding-top: 25px !important;
            padding-bottom: 25px !important;
        }

        .logo-admin {
            width: 110px;
            height: 110px;
            object-fit: contain;
            margin-right: 20px;
        }

        .menu-bar {
            background: #16a34a;
        }

        .menu-item {
            font-weight: 600;
            padding: 10px;
            transition: .3s;
        }

            .menu-item:hover {
                background: rgba(255,255,255,.15);
            }

        .menu-link {
            color: white;
            text-decoration: none;
            display: block;
        }

            .menu-link:hover {
                color: white;
            }

        .menu-admin {
            position: relative;
            display: inline-block;
        }

        .btn-saludo {
            background: transparent;
            color: white;
            border: none;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
        }

            .btn-saludo:focus {
                outline: none;
            }

        .menu-salir {
            display: none;
            position: absolute;
            right: 0;
            top: 40px;
            background: white;
            min-width: 180px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,.15);
            overflow: hidden;
            z-index: 1000;
        }

        .btn-cerrar {
            width: 100%;
            border: none;
            background: white;
            padding: 12px 15px;
            text-align: left;
            cursor: pointer;
        }

            .btn-cerrar:hover {
                background: #f5f5f5;
                color: #16a34a;
            }

        .contenido {
            margin-top: 60px;
        }

        .bienvenida {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,.08);
        }
    </style>
</head>

<body>

    <!-- ENCABEZADO -->
    <div class="container-fluid">

        <div class="row header-admin text-white align-items-center">

            <div class="col-md-6">

                <div class="d-flex align-items-center">

                    <img src="~/images/logo.png"
                         alt="Logo PropósitoFit"
                         class="logo-admin" />

                    <div>
                        <h1 class="m-0 fw-bold">PropósitoFit</h1>
                        <div style="font-size:18px;color:#d1d5db;">
                            Panel Administrativo
                        </div>
                    </div>

                </div>

            </div>

            <div class="col-md-6 text-end">

                <div class="menu-admin">

                    <button type="button"
                            onclick="mostrarMenu(event)"
                            class="btn-saludo">
                        Hola, @nombreUsuario ▼
                    </button>

                    <div id="menuSalir" class="menu-salir">

                        <button type="button"
                                onclick="location.href='@Url.Action("CerrarSesion", "Acceso")'"
                                class="btn-cerrar">
                            Cerrar sesión
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- MENÚ -->
        <div class="row menu-bar text-center text-white">

            <div class="col menu-item">
                <a asp-controller="Admin"
                   asp-action="Index"
                   class="menu-link">
                    Inicio
                </a>
            </div>

            <div class="col menu-item">
                <a asp-controller="Admin"
                   asp-action="Usuarios"
                   class="menu-link">
                    Usuarios
                </a>
            </div>

            <div class="col menu-item">
                <a href="#" class="menu-link">
                    Ejercicios
                </a>
            </div>

            <div class="col menu-item">
                <a href="#" class="menu-link">
                    Rutinas
                </a>
            </div>

            <div class="col menu-item">
                <a href="#" class="menu-link">
                    Alimentación
                </a>
            </div>

            <div class="col menu-item">
                <a href="#" class="menu-link">
                    Reportes
                </a>
            </div>

        </div>

    </div>

    <!-- CONTENIDO -->
    <div class="container contenido">

        <div class="bienvenida">

            <h2 class="fw-bold">
                Bienvenido al Panel Administrativo
            </h2>

            <p class="text-muted fs-5 mb-0">
                Administra los usuarios, ejercicios, rutinas, planes de alimentación y reportes del sistema PropósitoFit.
            </p>

        </div>

    </div>

    <script>

        function mostrarMenu(event) {

            event.stopPropagation();

            var menu = document.getElementById("menuSalir");

            if (menu.style.display === "block") {
                menu.style.display = "none";
            }
            else {
                menu.style.display = "block";
            }
        }

        document.addEventListener("click", function () {

            var menu = document.getElementById("menuSalir");

            menu.style.display = "none";

        });

    </script>

</body>
</html>