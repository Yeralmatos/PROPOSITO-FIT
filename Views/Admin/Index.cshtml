@using Microsoft.AspNetCore.Http
@{
    Layout = null;
    var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Panel Administrador - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: #f5f7fb;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #071527;
            position: fixed;
            padding: 25px 18px;
            color: white;
        }

        .brand {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 4px;
        }

            .brand span {
                color: #31c331;
            }

        .admin-label {
            color: #31c331;
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 35px;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 10px;
            margin-bottom: 10px;
            font-weight: 600;
        }

            .menu-link:hover,
            .menu-link.active {
                background: #20a820;
                color: white;
            }

        .content {
            margin-left: 260px;
            padding: 26px 38px;
        }

        .topbar {
            height: 62px;
            background: white;
            border-radius: 14px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 14px rgba(15, 23, 42, .06);
            margin-bottom: 28px;
        }

        .welcome {
            font-size: 30px;
            font-weight: 800;
            margin-bottom: 5px;
        }

        .module-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 24px;
            text-decoration: none;
            color: #111827;
            display: block;
            height: 100%;
            transition: .2s;
            box-shadow: 0 5px 16px rgba(15, 23, 42, .05);
        }

            .module-card:hover {
                transform: translateY(-3px);
                color: #111827;
                border-color: #31c331;
                box-shadow: 0 10px 24px rgba(15, 23, 42, .10);
            }

        .module-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .module-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: #eefbf0;
            color: #20a820;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin-bottom: 18px;
        }

        .module-count {
            font-size: 32px;
            font-weight: 800;
        }

        .panel {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 26px;
            box-shadow: 0 5px 16px rgba(15, 23, 42, .05);
        }

        .small-text {
            font-size: 14px;
            color: #6b7280;
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="brand">Propósito<span>Fit</span></div>
        <div class="admin-label">PANEL ADMINISTRADOR</div>

        <a href="/Admin/Index" class="menu-link active"><i class="bi bi-house-fill"></i> Dashboard</a>
        <a href="/Admin/Usuarios" class="menu-link"><i class="bi bi-people-fill"></i> Usuarios</a>
        <a href="/Admin/Ejercicios" class="menu-link"><i class="bi bi-dumbbell"></i> Ejercicios</a>
        <a href="/Admin/Rutinas" class="menu-link"><i class="bi bi-clipboard-check-fill"></i> Rutinas</a>
        <a href="/Admin/Objetivos" class="menu-link"><i class="bi bi-bullseye"></i> Objetivos</a>
        <a href="/Admin/Alimentacion" class="menu-link"><i class="bi bi-apple"></i> Alimentación</a>
        <a href="/Admin/Reportes" class="menu-link"><i class="bi bi-file-earmark-bar-graph-fill"></i> Reportes</a>
        <a href="/Acceso/CerrarSesion" class="menu-link"><i class="bi bi-box-arrow-left"></i> Cerrar Sesión</a>
    </div>

    <div class="content">

        <div class="topbar">
            <h4 class="fw-bold mb-0">Dashboard</h4>
            <strong>Hola, @nombreUsuario</strong>
        </div>

        <h1 class="welcome">Bienvenido, @nombreUsuario</h1>
        <p class="text-muted mb-4">Administra la información principal del sistema PropósitoFit.</p>

        <div class="row g-4 mb-4">

            <div class="col-md-3">
                <a href="/Admin/Usuarios" class="module-card">
                    <div class="module-icon"><i class="bi bi-people-fill"></i></div>
                    <p class="small-text mb-1">Usuarios registrados</p>
                    <div class="module-count">@ViewBag.TotalUsuarios</div>
                    <span class="text-success fw-bold">Gestionar usuarios</span>
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Admin/Ejercicios" class="module-card">
                    <div class="module-icon"><i class="bi bi-dumbbell"></i></div>
                    <p class="small-text mb-1">Ejercicios creados</p>
                    <div class="module-count">@ViewBag.TotalEjercicios</div>
                    <span class="text-success fw-bold">Gestionar ejercicios</span>
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Admin/Rutinas" class="module-card">
                    <div class="module-icon"><i class="bi bi-clipboard-check-fill"></i></div>
                    <p class="small-text mb-1">Rutinas creadas</p>
                    <div class="module-count">@ViewBag.TotalRutinas</div>
                    <span class="text-success fw-bold">Gestionar rutinas</span>
                </a>
            </div>

            <div class="col-md-3">
                <a href="/Admin/Objetivos" class="module-card">
                    <div class="module-icon"><i class="bi bi-bullseye"></i></div>
                    <p class="small-text mb-1">Objetivos registrados</p>
                    <div class="module-count">@ViewBag.TotalObjetivos</div>
                    <span class="text-success fw-bold">Gestionar objetivos</span>
                </a>
            </div>

        </div>

        <div class="panel">
            <h4 class="fw-bold mb-3">Módulos del sistema</h4>

            <div class="row g-3">

                <div class="col-md-4">
                    <a href="/Admin/Usuarios" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-people-fill text-success"></i> Usuarios</h5>
                        <p class="text-muted mb-0">Crear, editar y eliminar usuarios del sistema.</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="/Admin/Ejercicios" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-dumbbell text-success"></i> Ejercicios</h5>
                        <p class="text-muted mb-0">Administrar ejercicios, series, repeticiones, descanso y GIF.</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="/Admin/Rutinas" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-clipboard-check-fill text-success"></i> Rutinas</h5>
                        <p class="text-muted mb-0">Crear rutinas y asignar ejercicios en orden.</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="/Admin/Objetivos" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-bullseye text-success"></i> Objetivos</h5>
                        <p class="text-muted mb-0">Gestionar objetivos físicos disponibles.</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="/Admin/Alimentacion" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-apple text-success"></i> Alimentación</h5>
                        <p class="text-muted mb-0">Gestionar comidas y recomendaciones.</p>
                    </a>
                </div>

                <div class="col-md-4">
                    <a href="/Admin/Reportes" class="module-card">
                        <h5 class="fw-bold"><i class="bi bi-bar-chart-fill text-success"></i> Reportes</h5>
                        <p class="text-muted mb-0">Consultar estadísticas generales.</p>
                    </a>
                </div>

            </div>
        </div>

    </div>

</body>
</html>