@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var nombreUsuario =
        Context.Session.GetString("NombreUsuario")
        ?? "Administrador";
}

<h1 class="welcome">
    Bienvenido, @nombreUsuario
</h1>

<p class="text-muted mb-4">
    Administra la información principal del sistema PropósitoFit.
</p>

<div class="row g-4 mb-4">

    <div class="col-md-3">
        <a asp-controller="Admin"
           asp-action="Usuarios"
           class="module-card">

            <div class="module-icon">
                <i class="bi bi-people-fill"></i>
            </div>

            <p class="small-text mb-1">
                Usuarios registrados
            </p>

            <div class="module-count">
                @ViewBag.TotalUsuarios
            </div>

            <span class="text-success fw-bold">
                Gestionar usuarios
            </span>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Admin"
           asp-action="Ejercicios"
           class="module-card">

            <div class="module-icon">
                <i class="bi bi-dumbbell"></i>
            </div>

            <p class="small-text mb-1">
                Ejercicios creados
            </p>

            <div class="module-count">
                @ViewBag.TotalEjercicios
            </div>

            <span class="text-success fw-bold">
                Gestionar ejercicios
            </span>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Admin"
           asp-action="Rutinas"
           class="module-card">

            <div class="module-icon">
                <i class="bi bi-clipboard-check-fill"></i>
            </div>

            <p class="small-text mb-1">
                Rutinas creadas
            </p>

            <div class="module-count">
                @ViewBag.TotalRutinas
            </div>

            <span class="text-success fw-bold">
                Gestionar rutinas
            </span>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Admin"
           asp-action="Objetivos"
           class="module-card">

            <div class="module-icon">
                <i class="bi bi-bullseye"></i>
            </div>

            <p class="small-text mb-1">
                Objetivos registrados
            </p>

            <div class="module-count">
                @ViewBag.TotalObjetivos
            </div>

            <span class="text-success fw-bold">
                Gestionar objetivos
            </span>
        </a>
    </div>

</div>

<div class="panel">

    <h4 class="fw-bold mb-3">
        Módulos del sistema
    </h4>

    <div class="row g-3">

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Usuarios"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-people-fill text-success"></i>
                    Usuarios
                </h5>

                <p class="text-muted mb-0">
                    Crear, editar y eliminar usuarios del sistema.
                </p>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Ejercicios"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-dumbbell text-success"></i>
                    Ejercicios
                </h5>

                <p class="text-muted mb-0">
                    Administrar ejercicios, series, repeticiones,
                    descanso y GIF.
                </p>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Rutinas"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-clipboard-check-fill text-success"></i>
                    Rutinas
                </h5>

                <p class="text-muted mb-0">
                    Crear rutinas y asignar ejercicios en orden.
                </p>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Objetivos"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-bullseye text-success"></i>
                    Objetivos
                </h5>

                <p class="text-muted mb-0">
                    Gestionar objetivos físicos disponibles.
                </p>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Alimentacion"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-apple text-success"></i>
                    Alimentación
                </h5>

                <p class="text-muted mb-0">
                    Gestionar comidas y recomendaciones.
                </p>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Admin"
               asp-action="Reportes"
               class="module-card">

                <h5 class="fw-bold">
                    <i class="bi bi-bar-chart-fill text-success"></i>
                    Reportes
                </h5>

                <p class="text-muted mb-0">
                    Consultar estadísticas generales.
                </p>
            </a>
        </div>

    </div>

</div>
