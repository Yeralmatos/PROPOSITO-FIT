@model List<PropositoFit.Models.Usuario>

@{
    Layout = null;
    ViewData["Title"] = "Gestión de Clientes";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gestión de Clientes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f5f6fa;
            font-family: Arial, sans-serif;
        }

        .header {
            background: #111827;
            color: white;
            padding: 20px;
        }

        .card {
            border: none;
            border-radius: 15px;
        }

        .table th {
            vertical-align: middle;
        }

        .btn-accion {
            margin-right: 5px;
        }
    </style>
</head>

<body>

    <div class="header">
        <h2>Gestión de Clientes</h2>
    </div>

    <div class="container mt-4">

        <div class="d-flex justify-content-between mb-3">

            <a asp-action="Index"
               asp-controller="Admin"
               class="btn btn-secondary">
                ← Volver al Panel
            </a>

            <a asp-action="NuevoUsuario"
               asp-controller="Admin"
               class="btn btn-success">
                + Nuevo Cliente
            </a>

        </div>

        <div class="card shadow">

            <div class="card-body">

                <table class="table table-striped table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Usuario</th>
                            <th>Correo</th>
                            <th>Sexo</th>
                            <th>Estado</th>
                            <th>Rol</th>
                            <th>Fecha Registro</th>
                            <th width="220">Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var usuario in Model)
                        {
                            <tr>

                                <td>@usuario.Id</td>

                                <td>@usuario.NombreCliente</td>

                                <td>@usuario.NombreUsuario</td>

                                <td>@usuario.Correo</td>

                                <td>@usuario.Sexo</td>

                                <td>

                                    @if (usuario.Estado == "Activo")
                                    {
                                        <span class="badge bg-success">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactivo
                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (usuario.Rol == "Admin")
                                    {
                                        <span class="badge bg-danger">
                                            Administrador
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">
                                            Cliente
                                        </span>
                                    }

                                </td>

                                <td>
                                    @usuario.FechaRegistro.ToString("dd/MM/yyyy")
                                </td>

                                <td>

                                    <a asp-controller="Admin"
                                       asp-action="EditarUsuario"
                                       asp-route-id="@usuario.Id"
                                       class="btn btn-warning btn-sm">

                                        Editar

                                    </a>

                                    <form asp-controller="Admin"
                                          asp-action="EliminarUsuario"
                                          method="post"
                                          style="display:inline;">

                                        <input type="hidden"
                                               name="id"
                                               value="@usuario.Id" />

                                        <button type="submit"
                                                class="btn btn-danger btn-sm"
                                                onclick="return confirm('¿Desea eliminar este cliente?');">

                                            Eliminar

                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>
</html>