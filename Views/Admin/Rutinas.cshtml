@model List<PropositoFit.Models.Rutina>

@{
    ViewData["Title"] = "Rutinas";
}

<style>
    .card-box {
        background: white;
        border-radius: 18px;
        padding: 24px;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
    }

    .title {
        font-weight: 800;
        color: #111827;
    }

    .btn-green {
        background: #16a34a;
        color: white;
        border-radius: 10px;
        padding: 10px 16px;
        text-decoration: none;
    }

        .btn-green:hover {
            background: #15803d;
            color: white;
        }

    .badge-nivel {
        background: #dcfce7;
        color: #166534;
        padding: 7px 12px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-estado {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 7px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="title mb-1">
            <i class="bi bi-calendar-heart"></i> Gestión de Rutinas
        </h2>
        <p class="text-muted mb-0">
            Administra las rutinas disponibles para cada objetivo físico.
        </p>
    </div>

    <a href="/Admin/NuevaRutina" class="btn-green">
        <i class="bi bi-plus-circle"></i> Nueva rutina
    </a>
</div>

<div class="card-box mb-4">
    <form method="get" action="/Admin/Rutinas" class="row g-2">
        <div class="col-md-10">
            <input type="text"
                   name="buscar"
                   value="@ViewBag.Buscar"
                   class="form-control"
                   placeholder="Buscar por nombre, descripción o nivel..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-dark w-100">
                <i class="bi bi-search"></i> Buscar
            </button>
        </div>
    </form>
</div>

<div class="card-box">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Nivel</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Nombre</strong></td>
                            <td>@item.Descripcion</td>
                            <td><span class="badge-nivel">@item.Nivel</span></td>
                            <td><span class="badge-estado">@item.Estado</span></td>
                            <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>

                            <td class="text-end">
                                <a href="/Admin/EditarRutina/@item.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>

                                <form method="post" action="/Admin/EliminarRutina" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('¿Seguro que deseas eliminar esta rutina?')">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No hay rutinas registradas.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
