@model PropositoFit.Models.Usuario

@{
    Layout = null;
    ViewData["Title"] = "Editar Cliente";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Editar Cliente</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#f5f6fa;">

    <div class="container mt-5">

        <div class="card shadow">

            <div class="card-body">

                <h2 class="mb-4">Editar Cliente</h2>

                <form asp-controller="Admin"
                      asp-action="EditarUsuario"
                      method="post">

                    <input asp-for="Id" type="hidden" />

                    <!-- Nombre del Cliente -->
                    <div class="mb-3">
                        <label asp-for="NombreCliente" class="form-label"></label>
                        <input asp-for="NombreCliente" class="form-control" required />
                        <span asp-validation-for="NombreCliente" class="text-danger"></span>
                    </div>

                    <!-- Nombre de Usuario -->
                    <div class="mb-3">
                        <label asp-for="NombreUsuario" class="form-label"></label>
                        <input asp-for="NombreUsuario" class="form-control" required />
                        <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                    </div>

                    <!-- Cédula -->
                    <div class="mb-3">
                        <label asp-for="Cedula" class="form-label"></label>
                        <input asp-for="Cedula" class="form-control" required />
                        <span asp-validation-for="Cedula" class="text-danger"></span>
                    </div>

                    <!-- Correo -->
                    <div class="mb-3">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo"
                               type="email"
                               class="form-control"
                               required />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <!-- Contraseña -->
                    <div class="mb-3">
                        <label asp-for="Contrasena" class="form-label"></label>
                        <input asp-for="Contrasena"
                               type="password"
                               class="form-control"
                               required />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <!-- Fecha de nacimiento -->
                    <div class="mb-3">
                        <label asp-for="FechaNacimiento" class="form-label"></label>
                        <input asp-for="FechaNacimiento"
                               type="date"
                               class="form-control"
                               required />
                        <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                    </div>

                    <!-- Sexo -->
                    <div class="mb-3">
                        <label asp-for="Sexo" class="form-label"></label>

                        <select asp-for="Sexo" class="form-select" required>
                            <option value="">Seleccione</option>
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                            <option value="Otro">Otro</option>
                        </select>

                        <span asp-validation-for="Sexo" class="text-danger"></span>
                    </div>

                    <!-- Peso -->
                    <div class="mb-3">
                        <label asp-for="Peso" class="form-label">Peso (Libras)</label>
                        <input asp-for="Peso" class="form-control" required />
                        <span asp-validation-for="Peso" class="text-danger"></span>
                    </div>

                    <!-- Estatura -->
                    <div class="mb-3">
                        <label asp-for="Estatura" class="form-label"></label>
                        <input asp-for="Estatura" class="form-control" required />
                        <span asp-validation-for="Estatura" class="text-danger"></span>
                    </div>

                    <!-- Estado -->
                    <div class="mb-3">
                        <label asp-for="Estado" class="form-label"></label>

                        <select asp-for="Estado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>

                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <!-- Rol -->
                    <div class="mb-3">
                        <label asp-for="Rol" class="form-label"></label>

                        <select asp-for="Rol" class="form-select">
                            <option value="Cliente">Cliente</option>
                            <option value="Admin">Administrador</option>
                        </select>

                        <span asp-validation-for="Rol" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-warning">
                        Guardar Cambios
                    </button>

                    <a asp-controller="Admin"
                       asp-action="Usuarios"
                       class="btn btn-secondary">
                        Cancelar
                    </a>

                </form>

            </div>

        </div>

    </div>

</body>
</html>