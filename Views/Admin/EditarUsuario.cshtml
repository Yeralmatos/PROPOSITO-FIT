@model PropositoFit.Models.Usuario

@{
    Layout = null;
    ViewData["Title"] = "Editar Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Editar Usuario</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#f5f6fa;">

    <div class="container mt-5">

        <div class="card shadow">
            <div class="card-body">

                <h2 class="mb-4">Editar Usuario</h2>

                <form asp-controller="Admin" asp-action="EditarUsuario" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label>Nombre</label>
                        <input asp-for="Nombre" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Correo</label>
                        <input asp-for="Correo" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Contraseña</label>
                        <input asp-for="Contrasena" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Rol</label>
                        <select asp-for="Rol" class="form-control" required>
                            <option value="Usuario">Usuario</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-warning">
                        Guardar Cambios
                    </button>

                    <a asp-controller="Admin" asp-action="Usuarios" class="btn btn-secondary">
                        Cancelar
                    </a>

                </form>

            </div>
        </div>

    </div>

</body>
</html>