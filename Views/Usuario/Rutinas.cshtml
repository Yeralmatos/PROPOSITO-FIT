@model List<PropositoFit.Models.Rutina>

@{
    Layout = null;
    var nombreUsuario = TempData["NombreUsuario"] ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Rutinas - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: #f4f6fb;
            font-family: Arial, sans-serif;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #0f1b2d;
            color: white;
            position: fixed;
            padding: 25px 18px;
        }

        .brand {
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 35px;
            text-align: center;
        }

            .brand span {
                color: #39b72f;
            }

        .menu-link {
            display: block;
            color: white;
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 8px;
            margin-bottom: 12px;
            font-size: 17px;
        }

            .menu-link:hover,
            .menu-link.active {
                background: #1f56d8;
                color: white;
            }

        .content {
            margin-left: 250px;
            padding: 25px;
        }

        .topbar {
            height: 60px;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin-bottom: 20px;
        }

        .rutina-card {
            background: white;
            border-radius: 16px;
            padding: 22px;
            box-shadow: 0 6px 25px rgba(0,0,0,.08);
            margin-bottom: 20px;
            border-left: 6px solid #1f56d8;
        }

            .rutina-card.completada {
                border-left-color: #39b72f;
                background: #f0fff4;
            }

        .badge-nivel {
            background: #e8f0ff;
            color: #1f56d8;
            padding: 7px 12px;
            border-radius: 20px;
            font-size: 13px;
        }

        .instrucciones {
            background: #f8fafc;
            border-radius: 12px;
            padding: 15px;
            margin-top: 12px;
            color: #374151;
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="brand">Propósito<span>Fit</span></div>

        <a href="/Usuario/Index" class="menu-link">🏠 Inicio</a>
        <a href="/Usuario/Objetivos" class="menu-link">🎯 Mis Objetivos</a>
        <a href="/Usuario/Rutinas" class="menu-link active">🏆 Rutinas</a>
        <a href="/Usuario/Alimentacion" class="menu-link">🍎 Alimentación</a>
        <a href="/Usuario/Progreso" class="menu-link">📈 Mi Progreso</a>
        <a href="/Usuario/MiPerfil" class="menu-link">👤 Mi Perfil</a>
        <a href="/Acceso/CerrarSesion" class="menu-link">🚪 Cerrar Sesión</a>
    </div>

    <div class="content">

        <div class="topbar">
            <strong>Hola, @nombreUsuario</strong>
        </div>

        <h2 class="fw-bold">Rutinas Personalizadas</h2>
        @if (ViewBag.ObjetivoActual != null)
        {
            <div class="alert alert-success">
                🎯 Objetivo seleccionado:
                <strong>@ViewBag.ObjetivoActual</strong>
            </div>
        }
        <p class="text-muted">
            Estas rutinas fueron generadas automáticamente según tus objetivos.
        </p>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning">
                Todavía no tienes rutinas generadas. Primero crea un objetivo en
                <a href="/Usuario/Objetivos">Mis Objetivos</a>.
            </div>
        }
        else
        {
            @foreach (var rutina in Model)
            {
                <div class="rutina-card @(rutina.Completada ? "completada" : "")">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>
                            <h4 class="fw-bold">
                                @rutina.Nombre
                            </h4>

                            <p class="text-muted mb-2">
                                @rutina.Descripcion
                            </p>

                            <span class="badge-nivel">
                                Nivel: @rutina.Nivel
                            </span>

                            <span class="badge bg-secondary ms-2">
                                @rutina.DuracionMinutos min
                            </span>
                        </div>

                        <div>
                            @if (rutina.Completada)
                            {
                                <span class="badge bg-success fs-6">
                                    <i class="bi bi-check-circle"></i>
                                    Completada
                                </span>
                            }
                            else
                            {
                                <form asp-controller="Usuario"
                                      asp-action="CompletarRutina"
                                      method="post">

                                    <input type="hidden" name="id" value="@rutina.Id" />

                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-check2-circle"></i>
                                        Completar Rutina
                                    </button>
                                </form>
                            }
                        </div>

                    </div>

                    <div class="instrucciones">
                        <strong>Qué hacer para cumplirla:</strong>
                        <p class="mb-0 mt-2">
                            @rutina.Instrucciones
                        </p>
                    </div>

                    @if (rutina.FechaCompletada != null)
                    {
                        <small class="text-success d-block mt-2">
                            Completada el @rutina.FechaCompletada.Value.ToShortDateString()
                        </small>
                    }

                </div>
            }
        }

    </div>

</body>
</html>