@using Microsoft.AspNetCore.Http
@using PropositoFit.Models
@model List<PropositoFit.Models.Rutina>

@{
    Layout = null;
    var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Usuario";

    var rutinaEjercicios = ViewBag.RutinaEjercicios as List<RutinaEjercicio> ?? new List<RutinaEjercicio>();
    var ejercicios = ViewBag.Ejercicios as List<Ejercicio> ?? new List<Ejercicio>();
    var completados = ViewBag.Completados as List<EjercicioCompletado> ?? new List<EjercicioCompletado>();
    var objetivoActual = ViewBag.ObjetivoActual as string ?? "Sin objetivo";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Rutinas - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background: #f7f8fb;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: #071426;
            color: white;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 27px;
            font-weight: 800;
            margin-bottom: 32px;
        }

            .logo span {
                color: #24c932;
            }

        .menu {
            flex: 1;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 14px;
            color: white;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-size: 16px;
            font-weight: 600;
        }

            .menu-link i {
                font-size: 19px;
                width: 22px;
            }

            .menu-link.active,
            .menu-link:hover {
                background: #10b62f;
                color: white;
            }

        .motivacion {
            margin-top: auto;
            background: rgba(255,255,255,.08);
            border-radius: 16px;
            padding: 16px 12px;
            text-align: center;
        }

        .content {
            margin-left: 240px;
            padding: 0 26px 28px;
        }

        .topbar {
            height: 72px;
            background: white;
            margin: 0 -26px 20px;
            padding: 0 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
        }

        .objective-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .objective-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #079b24;
            color: white;
            font-size: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .routine-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 18px;
            min-height: 455px;
        }

        .day-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: #079b24;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        .exercise-row {
            display: grid;
            grid-template-columns: 48px 1fr 34px;
            gap: 10px;
            align-items: center;
            margin-bottom: 12px;
        }

        .exercise-img {
            width: 44px;
            height: 44px;
            object-fit: cover;
            border-radius: 8px;
            background: #f1f5f9;
        }

        .exercise-name {
            font-size: 14px;
            font-weight: 700;
            margin: 0;
        }

        .exercise-info {
            font-size: 12px;
            color: #4b5563;
            margin: 0;
        }

        .check-box {
            width: 26px;
            height: 26px;
            border: 2px solid #22a447;
            color: #22a447;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            background: white;
        }

            .check-box.done {
                background: #22a447;
                color: white;
            }

        .recommend-box {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 22px;
            margin-top: 22px;
        }

        .rec-item {
            display: flex;
            align-items: center;
            gap: 12px;
            border-right: 1px solid #e5e7eb;
        }

            .rec-item:last-child {
                border-right: none;
            }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="logo">Propósito<span>Fit</span></div>

        <div class="menu">
            <a href="/Usuario/Index" class="menu-link">
                <i class="bi bi-house-door"></i> Inicio
            </a>

            <a href="/Usuario/Objetivos" class="menu-link">
                <i class="bi bi-bullseye"></i> Mis Objetivos
            </a>

            <a href="/Usuario/Rutinas" class="menu-link active">
                <i class="bi bi-activity"></i> Rutinas
            </a>

            <a href="/Usuario/Alimentacion" class="menu-link">
                <i class="bi bi-apple"></i> Alimentación
            </a>

            <a href="/Usuario/Progreso" class="menu-link">
                <i class="bi bi-graph-up"></i> Mi Progreso
            </a>

            <a href="/Usuario/MiPerfil" class="menu-link">
                <i class="bi bi-person"></i> Mi Perfil
            </a>

            <a href="/Acceso/CerrarSesion" class="menu-link">
                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
            </a>
        </div>

        <div class="motivacion">
            <div style="font-size:28px;">🏆</div>
            <h6 class="fw-bold mt-2">¡Sigue así!</h6>
            <p class="mb-2 small">La constancia hoy,<br />son los resultados mañana.</p>
            <div style="font-size:22px;color:#20c431;">♥</div>
        </div>
    </div>

    <div class="content">

        <div class="topbar">
            <h3 class="fw-bold mb-0">
                <i class="bi bi-list me-3"></i> Rutinas
            </h3>

            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-bell fs-4"></i>

                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:43px;height:43px;">
                    <i class="bi bi-person-fill fs-4 text-secondary"></i>
                </div>

                <strong>Hola, @nombreUsuario</strong>
                <i class="bi bi-chevron-down"></i>
            </div>
        </div>

        <div class="objective-card">
            <div class="d-flex align-items-center gap-4">
                <div class="objective-icon">
                    <i class="bi bi-speedometer2"></i>
                </div>

                <div>
                    <h5 class="text-success fw-bold mb-1">Objetivo seleccionado</h5>
                    <h2 class="fw-bold mb-1">@objetivoActual</h2>
                    <p class="mb-0">Rutinas generadas según tu objetivo seleccionado.</p>
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <div style="font-size:72px;">🏋️‍♀️</div>

                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;font-size:28px;">
                    <i class="bi bi-check-lg"></i>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold">Tu plan de rutina</h3>

            <button class="btn btn-light border px-4">
                <i class="bi bi-calendar3 me-2"></i> Plan personalizado
            </button>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="bg-white rounded-4 p-5 text-center shadow-sm">
                <h4 class="fw-bold">No tienes rutinas asignadas</h4>
                <p class="text-muted">Primero selecciona un objetivo.</p>
                <a href="/Usuario/Objetivos" class="btn btn-success">Ir a Mis Objetivos</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var rutina in Model)
                {
                    var ejerciciosDeRutina = rutinaEjercicios
                    .Where(re => re.RutinaId == rutina.Id)
                    .OrderBy(re => re.Orden)
                    .ToList();

                    var completadosRutina = completados
                    .Where(c => c.RutinaId == rutina.Id)
                    .ToList();

                    bool rutinaCompletada = ejerciciosDeRutina.Any()
                    && ejerciciosDeRutina.All(re => completadosRutina.Any(c => c.EjercicioId == re.EjercicioId));

                    <div class="col-md-6 col-xl-4">
                        <div class="routine-card">

                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="day-icon">
                                    <i class="bi bi-calendar-week"></i>
                                </div>

                                <div>
                                    <h5 class="text-success fw-bold mb-0">@rutina.Nivel</h5>
                                    <h5 class="fw-bold mb-0">@rutina.Nombre</h5>
                                </div>
                            </div>

                            <div class="d-flex gap-4 text-muted mb-3 small">
                                <span><i class="bi bi-clock"></i> @ejerciciosDeRutina.Count ejercicios</span>
                                <span><i class="bi bi-house"></i> En casa</span>
                            </div>

                            <hr />

                            @foreach (var re in ejerciciosDeRutina)
                            {
                                var ejercicio = ejercicios.FirstOrDefault(e => e.Id == re.EjercicioId);

                                if (ejercicio != null)
                                {
                                    bool estaCompletado = completados.Any(c =>
                                    c.RutinaId == rutina.Id &&
                                    c.EjercicioId == ejercicio.Id);

                                    <div class="exercise-row">
                                        <div>
                                            @if (!string.IsNullOrWhiteSpace(ejercicio.Gif))
                                            {
                                                <img src="/gifs/@ejercicio.Gif" class="exercise-img" />
                                            }
                                            else
                                            {
                                                <div style="font-size:30px;">🏋️</div>
                                            }
                                        </div>

                                        <div>
                                            <p class="exercise-name">@ejercicio.Nombre</p>
                                            <p class="exercise-info">
                                                @re.Repeticiones repeticiones x @re.Series veces
                                            </p>
                                            <p class="exercise-info">
                                                Descanso: @re.DescansoSegundos seg.
                                            </p>
                                        </div>

                                        <div>
                                            @if (estaCompletado)
                                            {
                                                <div class="check-box done">
                                                    <i class="bi bi-check"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <form method="post" action="/Usuario/CompletarEjercicio">
                                                    <input type="hidden" name="rutinaId" value="@rutina.Id" />
                                                    <input type="hidden" name="ejercicioId" value="@ejercicio.Id" />

                                                    <button type="submit" class="check-box">
                                                        <i class="bi bi-check"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                }
                            }

                            <div class="d-flex align-items-center justify-content-between mt-3">
                                @if (rutinaCompletada)
                                {
                                    <span>
                                        <i class="bi bi-check-circle-fill me-2 text-success"></i>Completada
                                    </span>

                                    <button type="button" class="btn btn-success px-4" disabled>
                                        Completada
                                    </button>
                                }
                                else
                                {
                                    <span>
                                        <i class="bi bi-circle me-2"></i>Pendiente
                                    </span>

                                    <form method="post" action="/Usuario/CompletarRutina">
                                        <input type="hidden" name="rutinaId" value="@rutina.Id" />
                                        <button type="submit" class="btn btn-success px-4">
                                            Marcar completada
                                        </button>
                                    </form>
                                }
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

        <div class="recommend-box">
            <h5 class="fw-bold mb-4">
                <i class="bi bi-star me-2"></i> Recomendaciones
            </h5>

            <div class="row">
                <div class="col-md-3 rec-item">
                    <div style="font-size:34px;">💧</div>
                    <p class="mb-0 small">Bebe suficiente agua antes, durante y después.</p>
                </div>

                <div class="col-md-3 rec-item">
                    <div style="font-size:34px;">👟</div>
                    <p class="mb-0 small">Haz un calentamiento antes de cada rutina.</p>
                </div>

                <div class="col-md-3 rec-item">
                    <div style="font-size:34px;">🌙</div>
                    <p class="mb-0 small">Descansa lo suficiente para recuperarte mejor.</p>
                </div>

                <div class="col-md-3 rec-item">
                    <div style="font-size:34px;">❤️</div>
                    <p class="mb-0 small">Sé constante, los cambios llegan con disciplina.</p>
                </div>
            </div>
        </div>

    </div>

</body>
</html>
