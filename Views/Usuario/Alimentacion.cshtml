@using Microsoft.AspNetCore.Http

@{
    Layout = null;
    var nombreUsuario = Context.Session.GetString("NombreUsuario") ?? "Usuario";
    var objetivoActual = ViewBag.ObjetivoActual as string ?? "Sin objetivo";
    var desayuno = ViewBag.Desayuno as string ?? "";
    var almuerzo = ViewBag.Almuerzo as string ?? "";
    var cena = ViewBag.Cena as string ?? "";
    var agua = ViewBag.Agua as string ?? "";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Alimentación - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#f4f6fb;">

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold">Alimentación</h2>
                <p class="text-muted">Recomendaciones según tu objetivo físico.</p>
            </div>

            <strong>Hola, @nombreUsuario</strong>
        </div>

        <div class="alert alert-success">
            <strong>Objetivo actual:</strong> @objetivoActual
        </div>

        <div class="row">

            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h5>Desayuno</h5>
                        <p>@desayuno</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h5>Almuerzo</h5>
                        <p>@almuerzo</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h5>Cena</h5>
                        <p>@cena</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card shadow h-100">
                    <div class="card-body">
                        <h5>Agua</h5>
                        <p>@agua</p>
                    </div>
                </div>
            </div>

        </div>

        <div class="card shadow mt-4">
            <div class="card-body">

                <h4 class="fw-bold mb-3">Registrar alimentación diaria</h4>

                <form method="post">

                    <div class="row">

                        <div class="col-md-4 mb-3">
                            <label>Comida consumida</label>
                            <input type="text" class="form-control" placeholder="Ej: arroz, pollo, ensalada">
                        </div>

                        <div class="col-md-4 mb-3">
                            <label>Calorías aproximadas</label>
                            <input type="number" class="form-control" placeholder="Ej: 650">
                        </div>

                        <div class="col-md-4 mb-3">
                            <label>Agua consumida (litros)</label>
                            <input type="number" step="0.1" class="form-control" placeholder="Ej: 2.5">
                        </div>

                    </div>

                    <button type="submit" class="btn btn-success">
                        Guardar Registro
                    </button>

                    <a href="/Usuario/Index" class="btn btn-secondary">
                        Volver
                    </a>

                </form>

            </div>
        </div>

    </div>

</body>
</html>