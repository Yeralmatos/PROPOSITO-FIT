@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Iniciar Sesión - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .login-container {
            min-height: 100vh;
        }

        .left-panel {
            background: linear-gradient(rgba(0,0,0,.65), rgba(0,0,0,.75)), url('/images/login-bg.jpg');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 60px;
        }

        .brand-title {
            font-size: 48px;
            font-weight: bold;
        }

            .brand-title span {
                color: #39b72f;
            }

        .brand-text span {
            color: #39b72f;
            font-weight: bold;
        }

        .feature-item {
            margin-top: 25px;
            font-size: 18px;
        }

            .feature-item i {
                color: #39b72f;
                margin-right: 12px;
                font-size: 22px;
            }

        .right-panel {
            background: #f8f9fa;
        }

        .login-box {
            width: 100%;
            max-width: 470px;
            background: white;
            padding: 45px;
            border-radius: 22px;
            box-shadow: 0 10px 35px rgba(0,0,0,.10);
        }

        .logo {
            width: 130px;
        }

        .form-control {
            height: 55px;
            border-radius: 10px;
        }

        .input-group-text {
            background: white;
            border-radius: 10px;
            color: #28a745;
            font-size: 20px;
        }

        .btn-login {
            height: 55px;
            background-color: #28a745;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 18px;
        }

            .btn-login:hover {
                background-color: #218838;
            }

        .btn-register {
            height: 55px;
            border-radius: 10px;
            font-weight: bold;
            color: #28a745;
            border: 1px solid #28a745;
        }

            .btn-register:hover {
                background: #28a745;
                color: white;
            }

        .forgot-link {
            color: #28a745;
            font-weight: 600;
            text-decoration: none;
        }

            .forgot-link:hover {
                text-decoration: underline;
            }

        .secure-text {
            font-size: 14px;
            color: #6c757d;
        }

        @@media (max-width: 768px) {
            .left-panel {
                display: none !important;
            }

            .right-panel {
                min-height: 100vh;
                padding: 20px;
            }

            .login-box {
                padding: 30px;
            }
        }
    </style>
</head>

<body>

    <div class="container-fluid login-container">
        <div class="row h-100">

            <!-- Panel Izquierdo -->
            <div class="col-md-5 left-panel d-flex flex-column justify-content-center">

                <h1 class="brand-title">
                    Propósito<span>Fit</span>
                </h1>

                <p class="fs-3 brand-text mt-4">
                    Planifica, entrena y alcanza <span>tus objetivos.</span>
                </p>

                <div class="mt-5">
                    <div class="feature-item">
                        <i class="bi bi-bullseye"></i> Define tus objetivos
                    </div>

                    <div class="feature-item">
                        <i class="bi bi-bar-chart-line"></i> Sigue tu progreso
                    </div>

                    <div class="feature-item">
                        <i class="bi bi-activity"></i> Rutinas personalizadas
                    </div>
                </div>

            </div>

            <!-- Panel Derecho -->
            <div class="col-md-7 right-panel d-flex justify-content-center align-items-center">

                <div class="login-box">

                    <img src="~/images/logo.png" class="logo d-block mx-auto mb-3" />

                    <h2 class="text-center fw-bold">
                        Iniciar Sesión
                    </h2>

                    <p class="text-center text-muted mb-4">
                        Accede a tu cuenta para continuar
                    </p>

                    <form asp-controller="Acceso" asp-action="Login" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Correo electrónico
                            </label>

                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope"></i>
                                </span>

                                <input type="email"
                                       name="Correo"
                                       class="form-control"
                                       placeholder="Ingresa tu correo electrónico"
                                       required />
                            </div>
                        </div>

                        <div class="mb-2">
                            <label class="form-label fw-semibold">
                                Contraseña
                            </label>

                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>

                                <input type="password"
                                       name="Clave"
                                       id="password"
                                       class="form-control"
                                       placeholder="Ingresa tu contraseña"
                                       required />

                                <button class="input-group-text border-start-0"
                                        type="button"
                                        onclick="mostrarPassword()">
                                    <i class="bi bi-eye" id="iconoOjo"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="recordarme" />
                                <label class="form-check-label" for="recordarme">
                                    Recordarme
                                </label>
                            </div>

                            <a href="/Acceso/OlvidastePassword" class="forgot-link">
                                ¿Olvidaste tu contraseña?
                            </a>
                        </div>

                        <button type="submit" class="btn btn-login text-white w-100 mb-4">
                            <i class="bi bi-arrow-right me-2"></i>
                            Iniciar Sesión
                        </button>

                    </form>

                    <div class="d-flex align-items-center my-3">
                        <hr class="flex-grow-1">
                        <span class="mx-3 text-muted">o</span>
                        <hr class="flex-grow-1">
                    </div>

                    <a href="/Acceso/Registro" class="btn btn-register w-100 d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-person"></i>
                        Crear cuenta nueva
                    </a>

                    <p class="text-center mt-4 secure-text">
                        <i class="bi bi-shield-check"></i>
                        Tu información está protegida
                    </p>

                </div>

            </div>

        </div>
    </div>

    <script>
        function mostrarPassword() {
            const password = document.getElementById("password");
            const icono = document.getElementById("iconoOjo");

            if (password.type === "password") {
                password.type = "text";
                icono.classList.remove("bi-eye");
                icono.classList.add("bi-eye-slash");
            } else {
                password.type = "password";
                icono.classList.remove("bi-eye-slash");
                icono.classList.add("bi-eye");
            }
        }
    </script>

</body>
</html>