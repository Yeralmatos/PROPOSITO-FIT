@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Registro - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            background: #0b1117;
            font-family: 'Segoe UI', Arial, sans-serif;
        }

        .registro-wrapper {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1.1fr;
        }

        .panel-visual {
            position: relative;
            background: linear-gradient(rgba(0,0,0,.35), rgba(0,0,0,.75)), url('/images/login-bg.jpg');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 55px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .marca {
            display: flex;
            align-items: center;
            gap: 15px;
        }

            .marca img {
                width: 72px;
                height: 72px;
                object-fit: contain;
            }

            .marca h1 {
                margin: 0;
                font-size: 34px;
                font-weight: 800;
            }

        .mensaje h2 {
            font-size: 42px;
            font-weight: 800;
            line-height: 1.1;
        }

        .mensaje p {
            max-width: 480px;
            color: #d1d5db;
            font-size: 17px;
            margin-top: 15px;
        }

        .datos-rapidos {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .dato {
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.18);
            backdrop-filter: blur(8px);
            padding: 14px 18px;
            border-radius: 14px;
            font-size: 14px;
        }

        .panel-formulario {
            background: #f4f7fb;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 35px;
        }

        .registro-card {
            width: 100%;
            max-width: 720px;
            background: white;
            border-radius: 22px;
            padding: 34px;
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
        }

            .registro-card h2 {
                font-weight: 800;
                color: #111827;
            }

            .registro-card .subtitulo {
                color: #6b7280;
                margin-bottom: 25px;
            }

        label {
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .form-control,
        .form-select {
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid #d1d5db;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: #16a34a;
                box-shadow: 0 0 0 .2rem rgba(22,163,74,.15);
            }

        .btn-crear {
            background: #16a34a;
            border: none;
            padding: 13px;
            border-radius: 12px;
            font-weight: 700;
        }

            .btn-crear:hover {
                background: #15803d;
            }

        .btn-login {
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
        }

        .nota {
            font-size: 13px;
            color: #6b7280;
            margin-top: 12px;
        }

        @@media (max-width: 900px) {
            .registro-wrapper {
                grid-template-columns: 1fr;
            }

            .panel-visual {
                min-height: 360px;
                padding: 35px;
            }

            .mensaje h2 {
                font-size: 34px;
            }
        }
    </style>
</head>

<body>

    <div class="registro-wrapper">

        <section class="panel-visual">

            <div class="marca">
                <img src="/images/logo.png" alt="Logo PropósitoFit">
                <div>
                    <h1>PropósitoFit</h1>
                    <span>Entrena con propósito</span>
                </div>
            </div>

            <div class="mensaje">
                <h2>Comienza tu cambio físico desde hoy.</h2>
                <p>
                    Crea tu perfil, registra tus datos físicos y recibe rutinas
                    adaptadas a tus objetivos: perder peso, ganar masa muscular,
                    tonificar o mejorar tu resistencia.
                </p>
            </div>

            <div class="datos-rapidos">
                <div class="dato"><i class="bi bi-lightning-charge-fill"></i> Rutinas personalizadas</div>
                <div class="dato"><i class="bi bi-graph-up-arrow"></i> Seguimiento de progreso</div>
                <div class="dato"><i class="bi bi-heart-pulse-fill"></i> Hábitos saludables</div>
            </div>

        </section>

        <section class="panel-formulario">

            <div class="registro-card">

                <h2>Crear cuenta</h2>
                <p class="subtitulo">
                    Completa tus datos para configurar tu perfil físico.
                </p>

                <form asp-controller="Acceso" asp-action="Registro" method="post">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>Nombre completo</label>
                            <input type="text" name="Nombre" class="form-control" placeholder="Ej: Yeral Matos" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Correo electrónico</label>
                            <input type="email" name="Correo" class="form-control" placeholder="ejemplo@gmail.com" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Contraseña</label>
                            <input type="password" name="Contrasena" class="form-control" placeholder="Crea una contraseña" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Confirmar contraseña</label>
                            <input type="password" name="ConfirmarContrasena" class="form-control" placeholder="Repite la contraseña" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Edad</label>
                            <input type="number" name="Edad" class="form-control" placeholder="Ej: 22" min="10" max="100" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Sexo</label>
                            <select name="Sexo" class="form-select" required>
                                <option value="">Seleccionar</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Peso actual (kg)</label>
                            <input type="number" step="0.01" name="Peso" class="form-control" placeholder="Ej: 75.5" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Estatura (m)</label>
                            <input type="number" step="0.01" name="Estatura" class="form-control" placeholder="Ej: 1.75" required>
                        </div>

                    </div>

                    <button type="submit" class="btn btn-success btn-crear w-100 mt-2">
                        Crear cuenta
                    </button>

                    <a href="/Acceso/Login" class="btn btn-outline-secondary btn-login w-100 mt-2">
                        Ya tengo una cuenta
                    </a>

                    <p class="nota text-center">
                        Tus datos serán utilizados para personalizar tus rutinas y seguimiento físico.
                    </p>

                </form>

            </div>

        </section>

    </div>

</body>
</html>