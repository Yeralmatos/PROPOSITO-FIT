@using Microsoft.AspNetCore.Http

@{
    var nombreUsuario =
        Context.Session.GetString("NombreUsuario")
        ?? "Administrador";

    var accionActual =
        ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - PropósitoFit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f5f7fb;
            font-family: Arial, sans-serif;
            color: #111827;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #071527;
            position: fixed;
            top: 0;
            left: 0;
            padding: 25px 18px;
            color: white;
            overflow-y: auto;
            z-index: 1000;
        }

        .brand {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 4px;
        }

            .brand span {
                color: #31c331;
            }

        .admin-label {
            color: #31c331;
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 35px;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 10px;
            margin-bottom: 10px;
            font-weight: 600;
            transition: .2s;
        }

            .menu-link:hover,
            .menu-link.active {
                background: #20a820;
                color: white;
            }

        .content {
            margin-left: 260px;
            min-height: 100vh;
            padding: 26px 38px;
        }

        .topbar {
            min-height: 62px;
            background: white;
            border-radius: 14px;
            padding: 14px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 14px rgba(15, 23, 42, .06);
            margin-bottom: 28px;
        }

        .module-card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 24px;
            text-decoration: none;
            color: #111827;
            display: block;
            height: 100%;
            transition: .2s;
            box-shadow: 0 5px 16px rgba(15, 23, 42, .05);
        }

            .module-card:hover {
                transform: translateY(-3px);
                color: #111827;
                border-color: #31c331;
                box-shadow: 0 10px 24px rgba(15, 23, 42, .10);
            }

        .module-icon {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            background: #eefbf0;
            color: #20a820;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin-bottom: 18px;
        }

        .module-count {
            font-size: 32px;
            font-weight: 800;
        }

        .panel {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 26px;
            box-shadow: 0 5px 16px rgba(15, 23, 42, .05);
        }

        .small-text {
            font-size: 14px;
            color: #6b7280;
        }

        @@media (max-width: 850px) {
            .sidebar {
                width: 220px;
            }

            .content {
                margin-left: 220px;
                padding: 20px;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <div class="sidebar">

        <div class="brand">
            Propósito<span>Fit</span>
        </div>

        <div class="admin-label">
            PANEL ADMINISTRADOR
        </div>

        <a asp-controller="Admin"
           asp-action="Index"
           class="menu-link @(accionActual == "Index" ? "active" : "")">

            <i class="bi bi-house-fill"></i>
            Dashboard
        </a>

        <a asp-controller="Admin"
           asp-action="Usuarios"
           class="menu-link @(accionActual == "Usuarios" || accionActual == "NuevoUsuario" || accionActual == "EditarUsuario" ? "active" : "")">

            <i class="bi bi-people-fill"></i>
            Usuarios
        </a>

        <a asp-controller="Admin"
           asp-action="Ejercicios"
           class="menu-link @(accionActual == "Ejercicios" || accionActual == "NuevoEjercicio" || accionActual == "EditarEjercicio" ? "active" : "")">

            <i class="bi bi-dumbbell"></i>
            Ejercicios
        </a>

        <a asp-controller="Admin"
           asp-action="Rutinas"
           class="menu-link @(accionActual == "Rutinas" || accionActual == "NuevaRutina" || accionActual == "EditarRutina" ? "active" : "")">

            <i class="bi bi-clipboard-check-fill"></i>
            Rutinas
        </a>

        <a asp-controller="Admin"
           asp-action="Objetivos"
           class="menu-link @(accionActual == "Objetivos" ? "active" : "")">

            <i class="bi bi-bullseye"></i>
            Objetivos
        </a>

        <a asp-controller="Admin"
           asp-action="Alimentacion"
           class="menu-link @(accionActual == "Alimentacion" ? "active" : "")">

            <i class="bi bi-apple"></i>
            Alimentación
        </a>

        <a asp-controller="Admin"
           asp-action="Reportes"
           class="menu-link @(accionActual == "Reportes" ? "active" : "")">

            <i class="bi bi-file-earmark-bar-graph-fill"></i>
            Reportes
        </a>

        <a asp-controller="Acceso"
           asp-action="CerrarSesion"
           class="menu-link">

            <i class="bi bi-box-arrow-left"></i>
            Cerrar sesión
        </a>

    </div>

    <main class="content">

        <div class="topbar">

            <h4 class="fw-bold mb-0">
                @ViewData["Title"]
            </h4>

            <strong>
                Hola, @nombreUsuario
            </strong>

        </div>

        @RenderBody()

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
