@{
    var titulo = ViewData["Title"] ?? "PropositoFit";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@titulo - PropositoFit</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            background: #f4f6f9;
            font-family: Arial, sans-serif;
        }

        .admin-sidebar {
            width: 250px;
            min-height: 100vh;
            background: #111827;
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            padding: 24px 18px;
        }

        .admin-logo {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 35px;
        }

            .admin-logo span {
                color: #22c55e;
            }

        .admin-menu a {
            display: block;
            color: #d1d5db;
            text-decoration: none;
            padding: 13px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-weight: 600;
        }

            .admin-menu a:hover {
                background: #22c55e;
                color: white;
            }

        .admin-content {
            margin-left: 250px;
            padding: 30px;
        }

        .admin-topbar {
            background: white;
            border-radius: 18px;
            padding: 18px 24px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .admin-title {
            font-weight: 800;
            color: #111827;
            margin: 0;
        }

        .admin-user {
            color: #374151;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <aside class="admin-sidebar">
        <div class="admin-logo">
            Propósito<span>Fit</span>
        </div>

        <nav class="admin-menu">
            <a href="/Admin/Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a href="/Admin/Usuarios"><i class="bi bi-people"></i> Usuarios</a>
            <a href="/Admin/Objetivos"><i class="bi bi-bullseye"></i> Objetivos</a>
            <a href="/Admin/Ejercicios"><i class="bi bi-activity"></i> Ejercicios</a>
            <a href="/Admin/Rutinas"><i class="bi bi-calendar-heart"></i> Rutinas</a>
            <a href="/Usuario/Alimentacion"><i class="bi bi-egg-fried"></i> Alimentación</a>
            <a href="/Reportes/Usuarios"><i class="bi bi-file-earmark-bar-graph"></i> Reportes</a>
            <a href="/Acceso/Login"><i class="bi bi-box-arrow-right"></i> Cerrar sesión</a>
        </nav>
    </aside>

    <main class="admin-content">
        <div class="admin-topbar">
            <h3 class="admin-title">@titulo</h3>
            <div class="admin-user">
                <i class="bi bi-person-circle"></i> Administrador
            </div>
        </div>

        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>